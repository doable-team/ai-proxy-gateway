{
  "name": "ai-proxy-gateway",
  "version": "0.1.1",
  "description": "A single-command local AI proxy gateway with OpenAI-compatible endpoints for OpenAI, Anthropic, and Gemini",
  "main": "dist/index.js",
  "bin": {
    "ai-proxy-gateway": "dist/index.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "npm test && cd web && npm test",
    "dev:server": "tsx watch src/index.ts",
    "dev:web": "cd web && npm run dev",
    "build:server": "node scripts/build-server.js",
    "build:web": "cd web && npm run build",
    "build": "npm run build:server && npm run build:web && node scripts/copy-web.js",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\""
  },
  "keywords": [
    "ai",
    "proxy",
    "gateway",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "llm",
    "api-proxy",
    "ai-gateway",
    "openai-compatible",
    "model-router",
    "streaming"
  ],
  "license": "MIT",
  "author": "MrBeanDev (https://github.com/mrbeandev)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrbeandev/ai-proxy-gateway.git"
  },
  "bugs": {
    "url": "https://github.com/mrbeandev/ai-proxy-gateway/issues"
  },
  "homepage": "https://github.com/mrbeandev/ai-proxy-gateway#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "open": "^10.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "concurrently": "^8.2.2",
    "esbuild": "^0.27.4",
    "supertest": "^7.2.2",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "vitest": {
    "environment": "node",
    "include": [
      "src/**/*.test.ts",
      "tests/**/*.test.ts"
    ],
    "poolOptions": {
      "forks": {
        "singleFork": true
      }
    }
  }
}
